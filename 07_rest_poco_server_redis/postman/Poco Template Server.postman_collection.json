{
	"info": {
		"_postman_id": "poco-template-server",
		"name": "Poco Template Server",
		"description": "Коллекция для проверки API Poco Template Server",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:8080"
		},
		{
			"key": "jwt_token",
			"value": ""
		},
		{
			"key": "organization_id",
			"value": "1"
		},
		{
			"key": "search_first_name",
			"value": "FirstName7"
		},
		{
			"key": "search_last_name",
			"value": "LastName7"
		},
		{
			"key": "search_organization",
			"value": "Org42"
		}
	],
	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "Get JWT Token",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    const json = pm.response.json();",
									"    if (json.token) {",
									"        pm.collectionVariables.set('jwt_token', json.token);",
									"    }",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": {
							"type": "basic",
							"basic": [
								{
									"key": "username",
									"value": "user",
									"type": "string"
								},
								{
									"key": "password",
									"value": "password",
									"type": "string"
								}
							]
						},
						"method": "POST",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/v1/auth",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "auth"]
						},
						"description": "Basic auth → JWT токен. Логин/пароль: user/password (проверка пароля пока не реализована)."
					},
					"response": []
				}
			]
		},
		{
			"name": "Hello World",
			"item": [
				{
					"name": "GET Hello World",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/v1/helloworld",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "helloworld"]
						}
					},
					"response": []
				},
				{
					"name": "GET Hello World (JWT)",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{jwt_token}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/v1/helloworld_jwt",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "helloworld_jwt"]
						},
						"description": "Требует Bearer токен. Сначала выполните Get JWT Token."
					},
					"response": []
				}
			]
		},
		{
			"name": "Organizations",
			"item": [
				{
					"name": "List Organizations",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/v1/organizations",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "organizations"]
						}
					}
				},
				{
					"name": "Create Organization",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"Org42\",\n  \"address\": \"Main Street 42\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/organizations",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "organizations"]
						}
					}
				}
			]
		},
		{
			"name": "Users",
			"item": [
				{
					"name": "List Users",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/v1/users",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "users"]
						}
					}
				},
				{
					"name": "Create User",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"first_name\": \"FirstName7\",\n  \"last_name\": \"LastName7\",\n  \"title\": \"Engineer\",\n  \"email\": \"user7@example.com\",\n  \"login\": \"login7\",\n  \"password\": \"password\",\n  \"organization_id\": {{organization_id}}\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/users",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "users"]
						}
					}
				},
				{
					"name": "Search Users (substrings/terms)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/v1/users?first_name={{search_first_name}}&last_name={{search_last_name}}&organization={{search_organization}}",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "users"],
							"query": [
								{
									"key": "first_name",
									"value": "{{search_first_name}}"
								},
								{
									"key": "last_name",
									"value": "{{search_last_name}}"
								},
								{
									"key": "organization",
									"value": "{{search_organization}}"
								}
							]
						},
						"description": "GET /api/v1/users with optional filters: first_name, last_name, organization"
					}
				}
			]
		},
		{
			"name": "Metrics",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{base_url}}/metrics",
					"host": ["{{base_url}}"],
					"path": ["metrics"]
				}
			},
			"response": []
		},
		{
			"name": "Swagger",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{base_url}}/swagger.yaml",
					"host": ["{{base_url}}"],
					"path": ["swagger.yaml"]
				}
			},
			"response": []
		}
	]
}
